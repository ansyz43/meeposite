# ─── Database ───────────────────────────────────────────────
DB_PASSWORD=changeme                          # Postgres password

# ─── Security (REQUIRED — app won't start without a real key) ──
SECRET_KEY=generate-a-64-char-random-string   # openssl rand -hex 32

# ─── OpenAI / LLM ──────────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-...                   # OpenRouter or OpenAI API key
OPENAI_BASE_URL=https://openrouter.ai/api/v1  # Leave empty for direct OpenAI

# ─── Telegram ──────────────────────────────────────────────
TELEGRAM_API_URL=                             # Custom Telegram API proxy
TELEGRAM_BOT_TOKEN_LOGIN=                     # Bot token for Telegram Login Widget

# ─── Web / CORS ────────────────────────────────────────────
CORS_ORIGINS=https://meepo.su                 # Comma-separated origins
API_URL=https://meepo.su                      # Public API URL (frontend build)

# ─── OAuth (optional) ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=
VITE_TELEGRAM_BOT_NAME=
VITE_TELEGRAM_BOT_ID=

# ─── Email (optional — reset password) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ─── Proxy (optional) ──────────────────────────────────────
PROXY_SECRET=
